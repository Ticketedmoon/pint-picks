rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isPartyMember(partyId) {
      return request.auth.uid in get(/databases/$(database)/documents/parties/$(partyId)).data.memberUids;
    }

    function isPartyCreator(partyId) {
      return request.auth.uid == get(/databases/$(database)/documents/parties/$(partyId)).data.createdBy;
    }

    // ─── Users ───
    // Users can read any profile (needed for leaderboard display names).
    // Users can only write their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── Parties ───
    match /parties/{partyId} {
      // Any signed-in user can read a party (needed for join-by-code lookup).
      // Any signed-in user can create a party.
      // Creator can update any field. Members can only update memberUids (leave).
      // Non-members can join by code (adding only their own UID to memberUids).
      // Only the creator can delete.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Creator can update any field
        isPartyCreator(partyId)
        || (
          // Members can only remove themselves from memberUids (leave party)
          isPartyMember(partyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
          && resource.data.memberUids.hasAll(request.resource.data.memberUids)
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
          && !(request.auth.uid in request.resource.data.memberUids)
        )
        || (
          // Allow join-by-code: non-member adding only their own UID to memberUids
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
          && request.resource.data.memberUids.hasAll(resource.data.memberUids)
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.auth.uid in request.resource.data.memberUids
        )
      );
      allow delete: if isSignedIn() && isPartyCreator(partyId);

      // ─── Picks (subcollection of party) ───
      // Members can read their OWN picks anytime. Other members' picks only when locked/complete (prevents cheating).
      // Users can write their own picks. Creator can delete any picks (for party deletion / member removal).
      match /picks/{uid} {
        allow read: if isSignedIn() && (
          isOwner(uid)
          || isAdmin()
          || (
            isPartyMember(partyId)
            && resource.data != null
            && get(/databases/$(database)/documents/parties/$(partyId)).data.status in ['locked', 'complete']
          )
        );
        allow write: if isSignedIn() && isOwner(uid) && isPartyMember(partyId);
        allow delete: if isSignedIn() && isPartyCreator(partyId);
      }

      // ─── Pick Unlocks (subcollection of party) ───
      // Only party creator can create unlock tokens.
      // The target user can read their own token (validated server-side).
      // Server-side API route handles marking tokens as used.
      match /pickUnlocks/{token} {
        allow read: if isSignedIn() && isPartyMember(partyId);
        allow create: if isSignedIn() && isPartyCreator(partyId);
        allow update: if isSignedIn() && isPartyMember(partyId);
        allow delete: if isSignedIn() && isPartyCreator(partyId);
      }

      // ─── Invites (subcollection of party) ───
      // Members can read invites. Only creator can write.
      match /invites/{email} {
        allow read: if isSignedIn() && isPartyMember(partyId);
        allow write: if isSignedIn() && isPartyCreator(partyId);
      }
    }

    // ─── Analytics ───
    // Any signed-in user can write analytics events (page views, clicks).
    // Updates needed for increment() on aggregated docs.
    // Only the admin user can read analytics data.

    function isAdmin() {
      return request.auth.uid == 'O9xgSWINxiZQQFi142PE1JI2u5C3';
    }

    // ─── Analytics General ───
    // Per-user aggregated analytics for non-tournament browsing.
    match /analytics_general/{uid} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ─── Analytics Tournament ───
    // Per-user per-tournament aggregated analytics.
    match /analytics_tournament/{docId} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ─── Major Notifications ───
    // Tracks which majors have had reminder emails sent (prevents duplicates).
    // Written by the server-side cron job, readable for admin visibility.
    match /major_notifications/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─── Deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
